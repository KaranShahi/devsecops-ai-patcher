# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# Optional: raises the NVD public rate limit from 5 to 50 req/30s.
# Get one free at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Optional: enables the LLM-assisted rule refinement pass in engine.py.
# Without this set, the engine still runs fully offline using deterministic
# Sigma/YARA templates.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
USE_LLM=false
